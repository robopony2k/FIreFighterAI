{
  "name": "fireline-command",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "generate-building-footprints": "node scripts/generate-building-footprints.mjs",
    "check": "tsc --noEmit --pretty false",
    "build": "tsc --project tsconfig.json",
    "dev": "node scripts/dev-server.cjs",
    "queue:next": "node skills/game-design-maintainer/scripts/work_queue_cli.mjs next",
    "queue:summary": "node skills/game-design-maintainer/scripts/work_queue_cli.mjs summary",
    "queue:validate": "node skills/game-design-maintainer/scripts/work_queue_cli.mjs validate",
    "world-audio:regression": "npm run build && node scripts/world-audio-regression.mjs",
    "sun:regression": "node scripts/seasonal-sun-regression.mjs",
    "fire:regression": "npm run build && node scripts/fire-regression.mjs",
    "evacuation:regression": "npm run build && node scripts/evacuation-regression.mjs",
    "growth:regression": "npm run build && node scripts/growth-regression.mjs",
    "settlement:regression": "npm run build && node scripts/settlement-lifecycle-regression.mjs",
    "terrain:eval": "npm run build && node scripts/terrain-eval.mjs",
    "terrain:eval:quick": "npm run build && node scripts/terrain-eval.mjs --size=massive --samples=1",
    "mapgen:regression": "npm run build && node scripts/mapgen-regression.mjs",
    "mapgen:regression:full": "npm run build && node scripts/mapgen-regression.mjs --full",
    "mapgen:regression:baseline": "npm run build && node scripts/mapgen-regression.mjs --write-baseline",
    "mapgen:regression:baseline:full": "npm run build && node scripts/mapgen-regression.mjs --full --write-baseline"
  },
  "devDependencies": {
    "@types/three": "^0.182.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "three": "^0.182.0"
  }
}
